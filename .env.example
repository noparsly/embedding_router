# ========================
# Intent Router 配置
# ========================

APP_ENV=prod
DATA_DIR=data
INTENT_CACHE_DIR=data/intents

# 在线 Embedding Provider。当前项目只保留腾讯云 / OpenAPI 在线 Embedding。
EMBEDDING_PROVIDER=tencent

# 相似度阈值（低于此值判定为未知意图）
ABS_THRESHOLD=0.6

# 歧义判定阈值（Top-1 与 Top-2 差值小于此值时判定为歧义）
GAP_THRESHOLD=0.03

# 返回 Top-K 个候选意图
TOP_K=3

# 歧义处理方式：clarify（返回歧义）/ pick_top1（直接选第一个）
AMBIGUOUS_ACTION=clarify

# ========================
# LLM Provider 配置（用于 llm_prompt 策略）
# ========================

# DeepSeek API（生产环境推荐）
LLM_API_KEY=your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=5

# 或使用 OpenAI
# LLM_API_KEY=your-openai-api-key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4

# ========================
# 腾讯云 Embedding 服务配置
# ========================

TENCENT_EMBEDDING_ENDPOINT=https://lkeap.tencentcloudapi.com
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_API_KEY=
TENCENT_MODEL=sn-large-multi-language-v0.2.5
TENCENT_TEXT_TYPE=
TENCENT_INSTRUCTION=
TENCENT_SERVICE=lkeap
TENCENT_VERSION=2024-05-22
TENCENT_REGION=ap-guangzhou
TENCENT_TOKEN=
TENCENT_TIMEOUT=60
TENCENT_MAX_BATCH_SIZE=7

# ========================
# 管理端安全配置
# ========================

# 设置后，/admin* 接口需要请求头 x-admin-api-key
ADMIN_API_KEY=change-me

# 运营平台向意图识别服务发布/刷新配置
ROUTER_SERVICE_URL=http://router:8000
ROUTER_ADMIN_API_KEY=change-me-router-admin-key
AUTO_PUBLISH_TO_ROUTER=true
